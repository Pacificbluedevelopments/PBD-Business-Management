// =============================================================================
// firestore.rules
// Pacific Blue Developments — Business Management Application
// -----------------------------------------------------------------------------
// Firestore Security Rules — updated to include settings collection.
//
// Role values stored in Firestore userroles/{uid} document, field "role":
//   "director" | "sales" | "supervisor" | "accounts"
//
// Access matrix:
//   directors   — full read/write on all collections
//   sales       — create + read leads; read projects + contacts; no staffmembers
//   supervisors — read projects; update specific project fields only; no leads
//   accounts    — read projects only
//   settings    — directors read/write; all other authenticated roles read only
//
// NOTE: Role enforcement on this app uses Firestore userroles collection
// (not Firebase Auth custom claims) for role lookup in the client. These
// security rules use custom claims as a secondary server-side guard.
// If custom claims are not set, director-level rules will not enforce at the
// database layer — ensure custom claims are set via Cloud Function for
// production hardening.
//
// Deploy with: firebase deploy --only firestore:rules
// =============================================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper functions
    // -------------------------------------------------------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function isDirector() {
      return isAuthenticated() && request.auth.token.role == "director";
    }

    function isSales() {
      return isAuthenticated() && request.auth.token.role == "sales";
    }

    function isSupervisor() {
      return isAuthenticated() && request.auth.token.role == "supervisor";
    }

    function isAccounts() {
      return isAuthenticated() && request.auth.token.role == "accounts";
    }

    // Returns true if a Supervisor write only touches permitted project fields
    function supervisorFieldsOnly() {
      let allowedFields = [
        "currentStage",
        "nextStage",
        "nextStageDate",
        "pipelineNotes",
        "updatedAt"
      ];
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(allowedFields);
    }

    // -------------------------------------------------------------------------
    // Collection: userroles
    // Any authenticated user can read their own role document.
    // Only Directors can write (role assignment done via console or Cloud Fn).
    // -------------------------------------------------------------------------
    match /userroles/{userId} {
      allow read:  if isAuthenticated() && request.auth.uid == userId;
      allow write: if isDirector();
    }

    // -------------------------------------------------------------------------
    // Collection: leads
    // Directors : full read/write
    // Sales     : create and read
    // Supervisor: no access
    // Accounts  : no access
    // -------------------------------------------------------------------------
    match /leads/{leadId} {
      allow read:          if isDirector() || isSales();
      allow create:        if isDirector() || isSales();
      allow update, delete:if isDirector();
    }

    // -------------------------------------------------------------------------
    // Collection: projects
    // Directors  : full read/write
    // Sales      : read only
    // Supervisors: read; update allowed fields only; no create/delete
    // Accounts   : read only
    // -------------------------------------------------------------------------
    match /projects/{projectId} {
      allow read:          if isDirector() || isSales() || isSupervisor() || isAccounts();
      allow create, delete:if isDirector();
      allow update:        if isDirector()
                           || (isSupervisor() && supervisorFieldsOnly());
    }

    // -------------------------------------------------------------------------
    // Collection: contacts
    // Directors : full read/write
    // Sales     : read only
    // Others    : no access
    // -------------------------------------------------------------------------
    match /contacts/{contactId} {
      allow read:               if isDirector() || isSales();
      allow create, update, delete: if isDirector();
    }

    // -------------------------------------------------------------------------
    // Collection: staffmembers
    // Directors only
    // -------------------------------------------------------------------------
    match /staffmembers/{staffId} {
      allow read, write: if isDirector();
    }

    // -------------------------------------------------------------------------
    // Collection: settings
    // Directors : full read/write
    // All other authenticated roles: read only
    // (Sales, Supervisor, Accounts need to read marketConditionsPct for
    //  pipeline calculations and display)
    // -------------------------------------------------------------------------
    match /settings/{docId} {
      allow read:        if isAuthenticated();
      allow write:       if isDirector();
    }

    // -------------------------------------------------------------------------
    // Catch-all: deny everything not explicitly permitted above
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
